    {
      "name": "Autenticación",
      "item": [
        {
          "name": "Login - ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('token', jsonData.user.idUsuario);",
                  "    pm.environment.set('usuario_rol', jsonData.user.rol);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"admin@veterinaria.com\",\n  \"contrasena\": \"Admin123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [ "{{base_url}}" ],
              "path": [ "auth", "login" ]
            }
          }
        },
